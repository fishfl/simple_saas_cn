
# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# 微信支付 v3 配置
# 商户号（mchid），在微信支付商户平台获取
WXPAY_MCH_ID=1600000000

# 应用 APPID（公众号/开放平台），在微信开放平台获取
WXPAY_APP_ID=wx1234567890abcdef

# 商户 API 私钥（PEM格式，换行符用 \n 替代）
# 在微信支付商户平台 > API安全 > 申请API证书 中下载
WXPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----

# 商户 API 证书序列号
# 在微信支付商户平台 > API安全 > API证书管理 中查看
WXPAY_SERIAL_NO=1DDE55AD98ED71D6EDD4A4A16996DE7B47773A8C

# API v3 密钥（32位，用于解密回调通知）
# 在微信支付商户平台 > API安全 > APIv3密钥 中设置
WXPAY_API_V3_KEY=your_32_character_api_v3_key_here

# 支付回调通知地址（必须是公网可访问的 HTTPS 地址）
# 本地开发可用 ngrok 等工具创建隧道
WXPAY_NOTIFY_URL=https://yourdomain.com/api/webhooks/wxpay

# Site URL
BASE_URL=http://localhost:3000
